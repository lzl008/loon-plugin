#!name=DYGang Ad Block
#!desc=拦截 dygang.net 悬浮/弹窗/跳转广告（Loon）
#!author=codex
#!date=2026-03-18

[Rule]
DOMAIN-SUFFIX,dyg123.net,REJECT
DOMAIN-SUFFIX,66hao.cc,REJECT
DOMAIN-SUFFIX,66tutup.com,REJECT
DOMAIN-SUFFIX,hao6v.cc,REJECT
DOMAIN-SUFFIX,5266ys.com,REJECT

[Rewrite]
^https?:\/\/www\.dygang\.net\/jtrtytcdz45yfh3456\.js - reject-dict
^https?:\/\/www\.dygang\.net\/1endsd5643\.js - reject-dict
^https?:\/\/www\.dygang\.net\/d\/tj\.js - reject-dict

[Script]
# 注入页面级拦截（去除悬浮、禁用 window.open/跳转）
type=http-response,pattern=^https?:\/\/www\.dygang\.net\/.*$,requires-body=1,timeout=5,script-path=data:application/javascript;base64,
